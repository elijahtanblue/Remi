generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Workspace ───────────────────────────────────────────────────────────────

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  slackInstalls      SlackWorkspaceInstall[]
  jiraInstalls       JiraWorkspaceInstall[]
  gmailInstalls      GmailWorkspaceInstall[]
  confluenceInstall  ConfluenceWorkspaceInstall?
  confluencePages    ConfluencePage[]
  users              User[]
  departments        Department[]
  issues        Issue[]
  slackThreads  SlackThread[]
  emailThreads  EmailThread[]
  summaryRuns   SummaryRun[]
  auditLogs     AuditLog[]
  deadLetters   QueueDeadLetter[]
  productEvents ProductEvent[]
  memoryConfig  WorkspaceMemoryConfig?
  memoryUnits   MemoryUnit[]

  @@map("workspaces")
}

// ─── Departments ─────────────────────────────────────────────────────────────

model Department {
  id                   String   @id @default(cuid())
  workspaceId          String
  name                 String
  jiraProjectPrefixes  String[]
  slackChannelPatterns String[]
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  workspace   Workspace    @relation(fields: [workspaceId], references: [id])
  issues      Issue[]
  memoryUnits MemoryUnit[]

  @@index([workspaceId])
  @@map("departments")
}

// ─── Integration Installs ────────────────────────────────────────────────────

model SlackWorkspaceInstall {
  id              String    @id @default(cuid())
  workspaceId     String
  slackTeamId     String    @unique
  slackTeamName   String
  botToken        String
  botUserId       String
  installedByUserId String?
  scopes          String[]
  installedAt     DateTime  @default(now())
  uninstalledAt   DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@index([slackTeamId])
  @@map("slack_workspace_installs")
}

model JiraWorkspaceInstall {
  id            String    @id @default(cuid())
  workspaceId   String
  jiraClientKey String    @unique
  jiraSiteUrl   String
  sharedSecret  String
  installedAt   DateTime  @default(now())
  uninstalledAt DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@index([jiraClientKey])
  @@map("jira_workspace_installs")
}

// ─── Users ───────────────────────────────────────────────────────────────────

model User {
  id          String   @id @default(cuid())
  workspaceId String
  displayName String?
  email       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace  Workspace       @relation(fields: [workspaceId], references: [id])
  slackUsers SlackUser[]
  jiraUsers  JiraUser[]
  crosswalks UserCrosswalk[]
  linkedIssueThreads IssueThreadLink[]

  @@index([workspaceId])
  @@map("users")
}

model SlackUser {
  id            String  @id @default(cuid())
  userId        String
  slackUserId   String
  slackTeamId   String
  slackUsername  String?
  slackRealName String?

  user User @relation(fields: [userId], references: [id])

  @@unique([slackUserId, slackTeamId])
  @@index([slackUserId])
  @@map("slack_users")
}

model JiraUser {
  id              String  @id @default(cuid())
  userId          String
  jiraAccountId   String
  jiraSiteUrl     String
  jiraDisplayName String?

  user User @relation(fields: [userId], references: [id])

  @@unique([jiraAccountId, jiraSiteUrl])
  @@index([jiraAccountId])
  @@map("jira_users")
}

model UserCrosswalk {
  id         String @id @default(cuid())
  userId     String
  source     String
  externalId String
  metadata   Json?

  user User @relation(fields: [userId], references: [id])

  @@unique([source, externalId])
  @@map("user_crosswalks")
}

// ─── Issues ──────────────────────────────────────────────────────────────────

model Issue {
  id                     String   @id @default(cuid())
  workspaceId            String
  jiraIssueId            String
  jiraIssueKey           String
  jiraSiteUrl            String
  title                  String
  status                 String?
  statusCategory         String?
  assigneeJiraAccountId  String?
  assigneeDisplayName    String?
  priority               String?
  issueType              String?
  rawPayload             Json?
  s3PayloadKey           String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  departmentId           String?

  workspace   Workspace         @relation(fields: [workspaceId], references: [id])
  department  Department?       @relation(fields: [departmentId], references: [id])
  events      IssueEvent[]
  threadLinks IssueThreadLink[]
  emailLinks  IssueEmailLink[]
  summaries   Summary[]
  memoryUnits MemoryUnit[]

  @@unique([jiraIssueId, jiraSiteUrl])
  @@index([workspaceId])
  @@index([jiraIssueKey])
  @@map("issues")
}

model IssueEvent {
  id              String    @id @default(cuid())
  issueId         String
  idempotencyKey  String    @unique
  eventType       String
  source          String
  actorExternalId String?
  changedFields   Json?
  rawPayload      Json
  s3PayloadKey    String?
  occurredAt      DateTime
  receivedAt      DateTime  @default(now())
  processedAt     DateTime?

  issue Issue @relation(fields: [issueId], references: [id])

  @@index([issueId, occurredAt])
  @@index([idempotencyKey])
  @@map("issue_events")
}

// ─── Slack Threads & Messages ────────────────────────────────────────────────

model SlackThread {
  id             String   @id @default(cuid())
  workspaceId    String
  slackTeamId    String
  channelId      String
  threadTs       String
  isChannelLevel Boolean  @default(false)
  channelName    String?
  permalink      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workspace  Workspace         @relation(fields: [workspaceId], references: [id])
  messages   SlackMessage[]
  issueLinks IssueThreadLink[]

  @@unique([slackTeamId, channelId, threadTs])
  @@index([workspaceId])
  @@map("slack_threads")
}

model SlackMessage {
  id             String    @id @default(cuid())
  threadId       String
  idempotencyKey String    @unique
  slackMessageTs String
  slackUserId    String
  text           String
  rawPayload     Json
  s3PayloadKey   String?
  source         String
  sentAt         DateTime
  receivedAt     DateTime  @default(now())
  processedAt    DateTime?

  thread SlackThread @relation(fields: [threadId], references: [id])

  @@index([threadId, sentAt])
  @@index([idempotencyKey])
  @@map("slack_messages")
}

// ─── Links ───────────────────────────────────────────────────────────────────

model IssueThreadLink {
  id             String    @id @default(cuid())
  issueId        String
  threadId       String
  linkedByUserId String?
  linkedAt       DateTime  @default(now())
  unlinkedAt     DateTime?

  issue    Issue       @relation(fields: [issueId], references: [id])
  thread   SlackThread @relation(fields: [threadId], references: [id])
  linkedBy User?       @relation(fields: [linkedByUserId], references: [id])

  @@unique([issueId, threadId])
  @@index([issueId])
  @@index([threadId])
  @@map("issue_thread_links")
}

// ─── Summaries ───────────────────────────────────────────────────────────────

model Summary {
  id            String   @id @default(cuid())
  issueId       String
  version       Int      @default(1)
  status        String   @default("current")
  content       Json
  triggerReason String
  inputHash     String
  generatedAt   DateTime @default(now())
  summaryRunId  String?

  issue      Issue       @relation(fields: [issueId], references: [id])
  summaryRun SummaryRun? @relation(fields: [summaryRunId], references: [id])

  @@index([issueId, version])
  @@index([issueId, status])
  @@map("summaries")
}

model SummaryRun {
  id             String    @id @default(cuid())
  workspaceId    String
  status         String    @default("pending")
  issueCount     Int       @default(0)
  completedCount Int       @default(0)
  failedCount    Int       @default(0)
  triggeredBy    String
  startedAt      DateTime  @default(now())
  completedAt    DateTime?
  error          String?

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  summaries Summary[]

  @@index([workspaceId])
  @@map("summary_runs")
}

// ─── Product Analytics ───────────────────────────────────────────────────────

model ProductEvent {
  id          String   @id @default(cuid())
  workspaceId String
  event       String
  actorId     String?
  properties  Json?
  occurredAt  DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId, event, occurredAt])
  @@index([event, occurredAt])
  @@map("product_events")
}

// ─── Operational ─────────────────────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(cuid())
  workspaceId String
  action      String
  actorType   String
  actorId     String?
  targetType  String?
  targetId    String?
  metadata    Json?
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId, createdAt])
  @@index([action])
  @@map("audit_logs")
}

model QueueDeadLetter {
  id          String    @id @default(cuid())
  workspaceId String?
  queue       String
  messageId   String?
  payload     Json
  error       String
  failedAt    DateTime  @default(now())
  retriedAt   DateTime?
  retryCount  Int       @default(0)

  workspace Workspace? @relation(fields: [workspaceId], references: [id])

  @@index([queue, failedAt])
  @@map("queue_dead_letters")
}

// ─── Confluence Integration ───────────────────────────────────────────────────

model ConfluenceWorkspaceInstall {
  id           String    @id @default(cuid())
  workspaceId  String    @unique
  cloudId      String
  siteUrl      String
  accessToken  String
  refreshToken String
  scopes       String[]
  installedAt     DateTime  @default(now())
  uninstalledAt   DateTime?
  tokenExpiresAt  DateTime?
  defaultSpaceKey String?

  workspace Workspace       @relation(fields: [workspaceId], references: [id])
  pages     ConfluencePage[]

  @@map("confluence_workspace_installs")
}

model ConfluencePage {
  id           String   @id @default(cuid())
  workspaceId  String
  installId    String
  issueId      String?
  departmentId String?
  confluencePageId String
  spaceKey     String?
  title        String
  pageUrl      String
  docType           String   // 'handoff' | 'summary' | 'escalation'
  confluenceVersion Int      @default(1)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  workspace Workspace                  @relation(fields: [workspaceId], references: [id])
  install   ConfluenceWorkspaceInstall @relation(fields: [installId], references: [id])

  @@index([workspaceId])
  @@index([issueId])
  @@map("confluence_pages")
}

// ─── Gmail Integration ────────────────────────────────────────────────────────

model GmailWorkspaceInstall {
  id                 String    @id @default(cuid())
  workspaceId        String    @unique
  serviceAccountJson String
  domain             String
  monitoredEmails    String[]
  // Stores { "email@domain.com": "historyId" } for incremental sync per mailbox
  mailboxHistoryIds  Json?
  installedAt        DateTime  @default(now())
  uninstalledAt      DateTime?

  workspace    Workspace     @relation(fields: [workspaceId], references: [id])
  emailThreads EmailThread[]

  @@map("gmail_workspace_installs")
}

model EmailThread {
  id             String   @id @default(cuid())
  workspaceId    String
  gmailInstallId String
  gmailThreadId  String
  subject        String?
  participants   Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  gmailInstall GmailWorkspaceInstall @relation(fields: [gmailInstallId], references: [id])
  workspace    Workspace             @relation(fields: [workspaceId], references: [id])
  messages     EmailMessage[]
  issueLinks   IssueEmailLink[]

  @@unique([gmailInstallId, gmailThreadId])
  @@index([workspaceId])
  @@map("email_threads")
}

model EmailMessage {
  id             String    @id @default(cuid())
  threadId       String
  gmailMessageId String    @unique
  fromEmail      String
  toEmails       String[]
  subject        String?
  bodySnippet    String
  receivedAt     DateTime
  idempotencyKey String    @unique
  processedAt    DateTime?
  createdAt      DateTime  @default(now())

  thread EmailThread @relation(fields: [threadId], references: [id])

  @@index([threadId, receivedAt])
  @@map("email_messages")
}

model IssueEmailLink {
  id         String    @id @default(cuid())
  issueId    String
  threadId   String
  method     String
  linkedAt   DateTime  @default(now())
  unlinkedAt DateTime?

  issue  Issue       @relation(fields: [issueId], references: [id])
  thread EmailThread @relation(fields: [threadId], references: [id])

  @@unique([issueId, threadId])
  @@index([issueId])
  @@index([threadId])
  @@map("issue_email_links")
}

// ─── Autonomous Memory ────────────────────────────────────────────────────────

model WorkspaceMemoryConfig {
  id                 String   @id @default(cuid())
  workspaceId        String   @unique
  enabled            Boolean  @default(false)
  excludedChannelIds String[]
  excludedUserIds    String[]
  trackedChannelIds  String[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@map("workspace_memory_configs")
}

model MemoryUnit {
  id          String   @id @default(cuid())
  workspaceId String
  scopeType   String   // 'issue_thread' | 'app_dm' | 'email_thread'
  scopeRef    String   // threadId for issue_thread/email_thread, slackUserId for app_dm
  issueId     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  departmentId String?

  workspace    Workspace                @relation(fields: [workspaceId], references: [id])
  issue        Issue?                   @relation(fields: [issueId], references: [id])
  department   Department?              @relation(fields: [departmentId], references: [id])
  observations MemoryObservation[]
  snapshots    MemorySnapshot[]
  proposals    MemoryWritebackProposal[]

  @@unique([workspaceId, scopeType, scopeRef])
  @@index([workspaceId])
  @@index([issueId])
  @@map("memory_units")
}

model MemoryObservation {
  id            String   @id @default(cuid())
  memoryUnitId  String
  category      String   // 'decision'|'action_item'|'blocker'|'open_question'|'status_update'|'owner_update'|'risk'
  content       String
  confidence    Float
  citationIds   String[]
  sourceApp     String?  // 'slack' | 'jira' | 'email' | future apps
  modelId       String
  promptVersion String
  extractedAt   DateTime @default(now())
  state         String   @default("active")  // 'active' | 'superseded'
  supersededAt  DateTime?

  memoryUnit MemoryUnit @relation(fields: [memoryUnitId], references: [id])

  @@index([memoryUnitId, extractedAt])
  @@map("memory_observations")
}

model MemorySnapshot {
  id            String   @id @default(cuid())
  memoryUnitId  String
  version       Int
  headline      String
  currentState  String
  keyDecisions  Json
  openActions   Json
  blockers      Json
  openQuestions Json
  owners        String[]
  dataSources   String[] // e.g. ['slack', 'jira', 'email']
  confidence    Float
  freshness     DateTime
  modelId       String
  promptVersion String
  sourceObsIds  String[]
  createdAt     DateTime @default(now())

  memoryUnit MemoryUnit               @relation(fields: [memoryUnitId], references: [id])
  proposals  MemoryWritebackProposal[]

  @@index([memoryUnitId, version])
  @@map("memory_snapshots")
}

model MemoryWritebackProposal {
  id            String    @id @default(cuid())
  memoryUnitId  String
  snapshotId    String
  target        String    // 'jira_comment'
  status        String    @default("draft") // 'draft'|'pending_approval'|'approved'|'applied'|'rejected'|'failed'
  payload       Json      // { jiraIssueKey: string; commentBody: string }
  citationIds   String[]
  confidence    Float
  modelId       String
  promptVersion String
  approvedBy    String?
  approvedAt    DateTime?
  appliedAt     DateTime?
  rejectedAt    DateTime?
  failureReason String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  memoryUnit MemoryUnit     @relation(fields: [memoryUnitId], references: [id])
  snapshot   MemorySnapshot @relation(fields: [snapshotId], references: [id])

  @@index([memoryUnitId])
  @@index([status])
  @@map("memory_writeback_proposals")
}
