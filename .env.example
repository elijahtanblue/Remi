# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://remi:remi_dev@localhost:5432/remi?schema=public"

# ─── Slack ────────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN="xoxb-your-bot-token"
SLACK_SIGNING_SECRET="your-signing-secret"
SLACK_APP_TOKEN="xapp-your-app-token"    # Socket Mode token (local dev only)
SLACK_SOCKET_MODE="true"                  # Use Socket Mode in dev (no ngrok needed for Slack)

# ─── Jira ─────────────────────────────────────────────────────────────────────
# BASE_URL is used in the Atlassian Connect descriptor.
# In dev, use your ngrok URL (required for Jira webhooks).
# In production, set to: https://api.memoremi.com
BASE_URL="http://localhost:3000"

# ─── Queue ────────────────────────────────────────────────────────────────────
# "memory" = in-process queue (dev), "sqs" = AWS SQS (production)
QUEUE_ADAPTER="memory"
SQS_REGION="us-east-1"
SQS_SLACK_EVENTS_URL=""
SQS_JIRA_EVENTS_URL=""
SQS_SUMMARY_JOBS_URL=""
SQS_BACKFILL_JOBS_URL=""

# ─── Storage ──────────────────────────────────────────────────────────────────
# "local" = write to .local-storage/ dir (dev), "s3" = AWS S3 (production)
STORAGE_ADAPTER="local"
S3_BUCKET=""
S3_REGION="us-east-1"

# ─── Admin ────────────────────────────────────────────────────────────────────
ADMIN_API_KEY="dev-admin-key"

# ─── Apps ─────────────────────────────────────────────────────────────────────
PORT=3000                        # API server port
NODE_ENV="development"

# Admin dashboard (apps/admin only)
API_URL="http://localhost:3000"  # URL the Next.js admin calls for backend data
# In production, set NEXT_PUBLIC_API_URL=https://api.memoremi.com
